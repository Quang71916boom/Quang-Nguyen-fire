rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidRLMemory(data) {
      return data.keys().hasAll(['games_played', 'bot_wins', 'bot_losses', 'bot_draws', 'q_table', 'recent_learnings']) &&
             data.games_played is number &&
             data.bot_wins is number &&
             data.bot_losses is number &&
             data.bot_draws is number &&
             data.q_table is string &&
             data.q_table.size() <= 1000000 &&
             data.recent_learnings is string &&
             data.recent_learnings.size() <= 1000000;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['history']) &&
             data.history is string &&
             data.history.size() <= 1000000;
    }

    match /game_data/{docId} {
      allow get: if isValidId(docId) && (docId == 'rl_memory' || docId == 'history');
      
      allow create: if isValidId(docId) && (
        (docId == 'rl_memory' && isValidRLMemory(incoming())) ||
        (docId == 'history' && isValidHistory(incoming()))
      );
      
      allow update: if isValidId(docId) && (
        (docId == 'rl_memory' && isValidRLMemory(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['games_played', 'bot_wins', 'bot_losses', 'bot_draws', 'q_table', 'recent_learnings'])) ||
        (docId == 'history' && isValidHistory(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['history']))
      );
    }
  }
}
